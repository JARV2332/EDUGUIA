# Groq (chat / informe IA) — https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key

# Mantenimiento parcial: solo landing EduKids activa; EDUGUIA/campus/admin en 503 (por defecto).
# Para reactivar todo el sitio: MAINTENANCE_MODE=false
# MAINTENANCE_MODE=false

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Solo servidor (crear usuarios del campus desde el admin). Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
